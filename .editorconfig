root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml}]
indent_size = 2

[*.{csproj,props,targets}]
indent_size = 2

[*.cs]
# Brug 'this.' kun hvor nødvendigt
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion

# 'var' præferencer
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion

# Moderne C#-stil
csharp_style_namespace_declarations = file_scoped:warning
csharp_prefer_braces = true:suggestion
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion

# Usings
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = outside_namespace:warning

# Naming: private fields med _camelCase
dotnet_naming_rule.private_fields_underscore.severity = suggestion
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_prefix
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_prefix.required_prefix = _
dotnet_naming_style.underscore_prefix.capitalization = camel_case

# CA-analyzer justeringer der ellers støjer i et lille projekt
dotnet_diagnostic.CA1848.severity = none   # LoggerMessage delegates — overkill her
dotnet_diagnostic.CA2007.severity = none   # ConfigureAwait — ikke relevant i worker/bot

# Tests: tillad underscores i testnavne (idiomatisk) og andre test-specifikke lempelser
[tests/**/*.cs]
dotnet_diagnostic.CA1707.severity = none   # Underscores i testnavne er ønsket
dotnet_diagnostic.CA1515.severity = none   # public test-typer er fint
dotnet_diagnostic.CA1861.severity = none
