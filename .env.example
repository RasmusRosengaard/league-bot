# Kopiér til .env og udfyld. .env er git-ignored og må ALDRIG committes.
# docker-compose indlæser automatisk .env.

# --- Database ---
# Adgangskode til Postgres-containeren (bruges af både postgres- og bot-servicen).
POSTGRES_PASSWORD=postgres

# --- Riot ---
# Riot-API-nøgle fra https://developer.riotgames.com
# OBS: en development-nøgle udløber hver 24. time. Brug en personal/production-nøgle til drift.
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Discord ---
# Bot-token fra https://discord.com/developers/applications -> din app -> Bot.
DISCORD_TOKEN=your-discord-bot-token

# Valgfri: sæt en guild-ID for at registrere slash-kommandoer instant under udvikling
# (uden den registreres de globalt og kan tage op til ~1 time at propagere).
# DISCORD_TEST_GUILD_ID=123456789012345678
